# MusiCue runtime configuration.
# install.bat copies this to .env if .env doesn't already exist.

# Where uploaded songs and analysis output are stored.
MUSICUE_STORAGE_ROOT=%USERPROFILE%\.musicue

# Where ffmpeg lives (set by install.bat to vendor/ffmpeg/bin/).
# Left empty here; run.bat prepends vendor/ffmpeg/bin to PATH explicitly.
MUSICUE_FFMPEG_PATH=

# uvicorn bind address — keep localhost for single-machine use.
MUSICUE_HOST=127.0.0.1
MUSICUE_PORT=8000
